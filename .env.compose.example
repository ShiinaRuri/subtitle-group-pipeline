# Main app public HTTP port. Visit http://localhost:8080 by default.
APP_HTTP_PORT=8080

# For a real domain with Caddy automatic HTTPS, set:
# CADDY_SITE_ADDRESS=1.xyz
# CORS_ORIGIN=https://1.xyz
# and expose 80/443 in compose.yml.
CADDY_SITE_ADDRESS=:80
CORS_ORIGIN=http://localhost:8080

# Frontend runtime API base. Keep /api/v1 when Caddy is in front of backend.
FRONTEND_API_BASE_URL=/api/v1
VITE_API_BASE_URL=/api/v1
BACKEND_UPSTREAM=127.0.0.1:3000

# Backend runtime.
# Leave DATABASE_URL empty when using the graphical initialization page.
# With the postgres profile, initialize with:
# postgresql://subtitle:subtitle@postgres:5432/subtitle?schema=public
DATABASE_URL=
UPLOAD_MAX_SIZE=536870912000
JWT_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
DATABASE_AUTO_UPGRADE=true

# Shared secret for backend <-> QQ bridge.
QQ_BRIDGE_TOKEN=change-this-to-a-long-random-secret
QQ_BRIDGE_PORT=8095
HEARTBEAT_INTERVAL_SECONDS=30
QQBOT_LOG_LEVEL=INFO

# Optional PostgreSQL service profile values.
POSTGRES_DB=subtitle
POSTGRES_USER=subtitle
POSTGRES_PASSWORD=subtitle

# Optional SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
