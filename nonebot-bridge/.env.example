DRIVER=~fastapi+~httpx
HOST=127.0.0.1
PORT=8095
LOG_LEVEL=INFO

# Backend base URL. The bridge calls POST {BACKEND_API_BASE}/qq/verify and /qq/heartbeat.
BACKEND_API_BASE=http://127.0.0.1:3000/api/v1

# Optional shared secret. Must match backend QQ_BRIDGE_TOKEN when configured.
QQ_BRIDGE_TOKEN=

# Heartbeat interval in seconds. Backend marks the bridge offline if heartbeats stop.
HEARTBEAT_INTERVAL_SECONDS=30
